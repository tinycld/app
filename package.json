{
    "name": "tinycld",
    "version": "1.13.7",
    "packageManager": "bun@1.3.12",
    "private": true,
    "license": "AGPL-3.0-only",
    "main": "expo-router/entry",
    "type": "module",
    "scripts": {
        "packages:generate": "bunx tsx scripts/generate-packages.ts",
        "packages:link": "bunx tsx scripts/link-package.ts link",
        "packages:unlink": "bunx tsx scripts/link-package.ts unlink",
        "packages:install": "bunx tsx scripts/install-package.ts",
        "postinstall": "bun run packages:generate",
        "predev": "bun run packages:generate",
        "prebuild:web": "bun run packages:generate",
        "android": "bunx expo run:android",
        "migrate": "./server/tinycld migrate",
        "build:web": "bunx expo export --platform web",
        "analyze:web": "EXPO_ATLAS=true bunx expo export --platform web && bunx expo-atlas .expo/atlas.jsonl",
        "dev": "run-p -r ssl:dev expo:dev pb:dev",
        "pb:dev": "./bin/pb-dev",
        "ssl:dev": "local-ssl-proxy  --source 7090 --target 7093 --cert ./assets/localhost.pem --key ./assets/localhost-key.pem",
        "dev:local": "run-p -l -r expo:dev ssl:dev pb:dev",
        "expo:dev": "bunx expo start --clear --port 7100",
        "expo:test": "EXPO_PUBLIC_ENV=test bunx expo start --port 7101",
        "dev:clean": "bunx expo start --port 7100 --clear",
        "ios:simulator": "bunx expo run:ios --device B5B76CBA-B42A-4C06-9D55-9B391BB4175F",
        "ios": "bunx expo run:ios",
        "prebuild:native": "bunx expo prebuild",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "typecheck": "tsc --noEmit --skipLibCheck",
        "checks": "bun run lint && bun run typecheck",
        "eas-build-post-install": "export EXPO_PUBLIC_GIT_COMMIT=$EAS_BUILD_GIT_COMMIT_HASH && ./scripts/eas-install-packages.sh && bun run packages:generate",
        "eas:build:ios": "bunx eas build --platform ios",
        "eas:build:ios:local": "bunx eas build --platform ios --local --output ./tmp/build.ipa",
        "eas:submit:ios": "bunx eas submit --platform ios",
        "eas:submit:ios:local": "bunx eas submit --platform ios --path ./tmp/build.ipa",
        "eas:release:ios": "run-s eas:build:ios eas:submit:ios",
        "eas:release:ios:local": "run-s eas:build:ios:local eas:submit:ios:local",
        "eas:update": "scripts/eas-update.sh production",
        "eas:update:preview": "scripts/eas-update.sh preview",
        "db:reset": "bunx tsx scripts/reset-dev-db.ts",
        "db:seed": "bunx tsx scripts/seed-db.ts",
        "db:seed:demo": "bunx tsx scripts/seed-db.ts --mode demo",
        "db:reset:demo": "bunx tsx scripts/reset-demo.ts",
        "test:e2e:debug": "NODE_OPTIONS=--preserve-symlinks playwright test --ui --headed --debug",
        "test:e2e": "NODE_OPTIONS=--preserve-symlinks bunx playwright test",
        "test:unit": "bunx vitest run",
        "test:server": "bunx tsx scripts/test-server-api.ts"
    },
    "dependencies": {
        "@10play/tentap-editor": "^1.0.1",
        "@expo/html-elements": "^0.12.5",
        "@gluestack-ui/core": "^5.0.0-alpha.0",
        "@gluestack-ui/utils": "^5.0.1-alpha.0",
        "@gorhom/bottom-sheet": "^5.2.9",
        "@hookform/resolvers": "^5.2.2",
        "@legendapp/motion": "^2.5.3",
        "@react-aria/checkbox": "^3.17.0",
        "@react-aria/dialog": "^3.6.0",
        "@react-aria/focus": "^3.22.0",
        "@react-aria/interactions": "^3.28.0",
        "@react-aria/label": "^3.8.0",
        "@react-aria/menu": "^3.22.0",
        "@react-aria/overlays": "^3.32.0",
        "@react-aria/radio": "^3.13.0",
        "@react-aria/selection": "^3.28.0",
        "@react-aria/ssr": "^3.10.0",
        "@react-aria/switch": "^3.8.0",
        "@react-aria/utils": "^3.34.0",
        "@react-aria/visually-hidden": "^3.9.0",
        "@react-native-async-storage/async-storage": "^3.0.2",
        "@react-native-community/netinfo": "11.5.2",
        "@react-native-menu/menu": "1.2.2",
        "@react-navigation/native": "~7.2.2",
        "@react-stately/checkbox": "^3.8.0",
        "@react-stately/collections": "^3.13.0",
        "@react-stately/menu": "^3.10.0",
        "@react-stately/overlays": "^3.7.0",
        "@react-stately/radio": "^3.12.0",
        "@react-stately/slider": "^3.8.0",
        "@react-stately/toggle": "^3.10.0",
        "@react-stately/tree": "^3.10.0",
        "@react-stately/utils": "^3.12.0",
        "@sentry/react-native": "^8.8.0",
        "@tanstack/db": "^0.6.1",
        "@tanstack/query-db-collection": "^1.0.36",
        "@tanstack/react-db": "^0.1.79",
        "@tanstack/react-query": "^5.96.0",
        "@tiptap/extension-link": "^3.22.3",
        "@tiptap/extension-placeholder": "^3.22.3",
        "@tiptap/extension-underline": "^3.22.3",
        "@tiptap/pm": "^3.22.3",
        "@tiptap/react": "^3.22.3",
        "@tiptap/starter-kit": "^3.22.3",
        "expo": "~55.0.7",
        "expo-clipboard": "~55.0.13",
        "expo-constants": "^55.0.15",
        "expo-crypto": "^55.0.12",
        "expo-dev-client": "~55.0.27",
        "expo-document-picker": "~55.0.11",
        "expo-file-system": "~55.0.17",
        "expo-image-picker": "^55.0.19",
        "expo-linking": "~55.0.12",
        "expo-notifications": "~55.0.16",
        "expo-router": "~55.0.13",
        "expo-sharing": "~55.0.18",
        "expo-updates": "~55.0.21",
        "fflate": "^0.8.2",
        "heroui-native": "^1.0.1",
        "ical.js": "^2.2.1",
        "isomorphic-webcrypto": "^2.3.8",
        "lucide-react-native": "^1.7.0",
        "pbtsdb": "^0.5.0",
        "pocketbase": "^0.26.8",
        "react": "19.2.0",
        "react-aria": "^3.47.0",
        "react-dom": "19.2.0",
        "react-hook-form": "^7.72.0",
        "react-native": "0.83.2",
        "react-native-draggable-flatlist": "^4.0.3",
        "react-native-external-keyboard": "^0.8.4",
        "react-native-gesture-handler": "^2.31.1",
        "react-native-get-random-values": "^2.0.0",
        "react-native-ios-context-menu": "^3.2.1",
        "react-native-ios-utilities": "^5.2.0",
        "react-native-reanimated": "4.2.1",
        "react-native-safe-area-context": "^5.7.0",
        "react-native-screens": "~4.23.0",
        "react-native-sse": "^1.2.1",
        "react-native-svg": "^15.15.4",
        "react-native-web": "^0.21.2",
        "react-native-webview": "^13.16.1",
        "react-native-worklets": "0.7.2",
        "react-pdf": "^10.4.1",
        "react-stately": "^3.45.0",
        "tailwind-merge": "^3.5.0",
        "tailwind-variants": "^0.1.20",
        "tinykeys": "^3.0.0",
        "typescript": "~5.9.2",
        "uniwind": "^1.6.2",
        "yjs": "^13.6.30",
        "zod": "^4.3.6",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.10",
        "@playwright/test": "^1.52.0",
        "@react-native-community/cli": "^20.1.2",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.2",
        "babel-plugin-module-resolver": "^5.0.3",
        "expo-atlas": "^0.4.3",
        "imapflow": "^1.3.1",
        "local-ssl-proxy": "^2.0.5",
        "npm-run-all2": "^8.0.4",
        "tailwindcss": "^4.2.2",
        "tsx": "^4.21.0",
        "vitest": "^3.0.0"
    }
}
