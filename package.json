{
    "name": "tinycld",
    "version": "1.13.7",
    "packageManager": "pnpm@11.1.1",
    "private": true,
    "license": "AGPL-3.0-only",
    "main": "expo-router/entry",
    "type": "module",
    "scripts": {
        "packages:generate": "pnpm exec tsx scripts/generate-packages.ts",
        "packages:link": "pnpm exec tsx scripts/link-package.ts link",
        "packages:unlink": "pnpm exec tsx scripts/link-package.ts unlink",
        "packages:install": "pnpm exec tsx scripts/install-package.ts",
        "assets:copy-pdfjs": "pnpm exec tsx scripts/copy-pdfjs-assets.ts",
        "postinstall": "pnpm run packages:generate && pnpm run assets:copy-pdfjs",
        "prebuild:web": "pnpm run packages:generate",
        "android": "pnpm exec expo run:android",
        "migrate": "./server/tinycld migrate",
        "build:web": "pnpm exec expo export --platform web",
        "analyze:web": "EXPO_ATLAS=true pnpm exec expo export --platform web && pnpm exec expo-atlas .expo/atlas.jsonl",
        "dev": "pnpm exec tsx scripts/dev.ts",
        "start": "pnpm exec tsx scripts/dev.ts",
        "ssl:generate": "scripts/generate-ssl.sh",
        "expo:test": "pnpm exec tsx scripts/reset-dev-db.ts --url http://127.0.0.1:7299 --data-dir server/pb_test_data && pnpm exec tsx scripts/dev.ts --no-ssl --port 7200 --pb-data-dir server/pb_test_data",
        "simulator": "scripts/ios-simulator.sh",
        "ios": "pnpm exec expo run:ios",
        "ios:build-only": "pnpm exec expo run:ios --no-bundler",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "typecheck": "tsc --noEmit --skipLibCheck",
        "checks": "pnpm run lint && pnpm run typecheck",
        "eas-build-post-install": "export EXPO_PUBLIC_GIT_COMMIT=$EAS_BUILD_GIT_COMMIT_HASH && ./scripts/eas-install-packages.sh && pnpm run packages:generate && pnpm run assets:copy-pdfjs",
        "eas:build:ios": "pnpm exec eas build --platform ios",
        "eas:build:ios:local": "pnpm exec eas build --platform ios --local --output ./tmp/build.ipa",
        "eas:submit:ios": "pnpm exec eas submit --platform ios",
        "eas:submit:ios:local": "pnpm exec eas submit --platform ios --path ./tmp/build.ipa",
        "eas:release:ios": "pnpm run eas:build:ios && pnpm run eas:submit:ios",
        "eas:release:ios:local": "pnpm run eas:build:ios:local && pnpm run eas:submit:ios:local",
        "db:reset": "pnpm exec tsx scripts/reset-dev-db.ts",
        "db:seed": "pnpm exec tsx scripts/seed-db.ts",
        "db:seed:demo": "pnpm exec tsx scripts/seed-db.ts --mode demo",
        "db:reset:demo": "pnpm exec tsx scripts/reset-demo.ts",
        "test:e2e:debug": "NODE_OPTIONS=--preserve-symlinks playwright test --ui --headed --debug",
        "test:e2e": "NODE_OPTIONS=--preserve-symlinks pnpm exec playwright test",
        "test:unit": "pnpm exec vitest run",
        "test:server": "pnpm exec tsx scripts/test-server-api.ts",
        "test:go": "cd server && go test -tags no_ui ./... tinycld.org/core/... tinycld.org/packages/..."
    },
    "dependencies": {
        "@10play/tentap-editor": "^1.0.1",
        "@expo/html-elements": "^0.12.5",
        "@gluestack-ui/core": "^5.0.0-alpha.0",
        "@gluestack-ui/utils": "^5.0.1-alpha.0",
        "@gorhom/bottom-sheet": "^5.2.9",
        "@hookform/resolvers": "^5.2.2",
        "@legendapp/motion": "^2.5.3",
        "@react-aria/checkbox": "^3.17.0",
        "@react-aria/dialog": "^3.6.0",
        "@react-aria/focus": "^3.22.0",
        "@react-aria/interactions": "^3.28.0",
        "@react-aria/label": "^3.8.0",
        "@react-aria/menu": "^3.22.0",
        "@react-aria/overlays": "^3.32.0",
        "@react-aria/radio": "^3.13.0",
        "@react-aria/selection": "^3.28.0",
        "@react-aria/ssr": "^3.10.0",
        "@react-aria/switch": "^3.8.0",
        "@react-aria/utils": "^3.34.0",
        "@react-aria/visually-hidden": "^3.9.0",
        "@react-native-async-storage/async-storage": "2.2.0",
        "@react-native-community/netinfo": "11.5.2",
        "@react-native-menu/menu": "1.2.2",
        "@react-navigation/native": "^7.1.33",
        "@react-stately/checkbox": "^3.8.0",
        "@react-stately/collections": "^3.13.0",
        "@react-stately/menu": "^3.10.0",
        "@react-stately/overlays": "^3.7.0",
        "@react-stately/radio": "^3.12.0",
        "@react-stately/slider": "^3.8.0",
        "@react-stately/toggle": "^3.10.0",
        "@react-stately/tree": "^3.10.0",
        "@react-stately/utils": "^3.12.0",
        "@sentry/react-native": "~7.11.0",
        "@shopify/flash-list": "2.0.2",
        "@tanstack/db": "^0.6.1",
        "@tanstack/query-db-collection": "^1.0.36",
        "@tanstack/react-db": "^0.1.79",
        "@tanstack/react-query": "^5.96.0",
        "@tiptap/extension-collaboration": "^3.22.3",
        "@tiptap/extension-collaboration-caret": "^3.22.3",
        "@tiptap/extension-image": "^3.22.3",
        "@tiptap/extension-link": "^3.22.3",
        "@tiptap/extension-placeholder": "^3.22.3",
        "@tiptap/extension-table": "^3.22.3",
        "@tiptap/extension-table-cell": "^3.22.3",
        "@tiptap/extension-table-header": "^3.22.3",
        "@tiptap/extension-table-row": "^3.22.3",
        "@tiptap/extension-underline": "^3.22.3",
        "@tiptap/pm": "^3.22.3",
        "@tiptap/react": "^3.22.3",
        "@tiptap/starter-kit": "^3.22.3",
        "expo": "~55.0.23",
        "expo-clipboard": "~55.0.13",
        "expo-constants": "~55.0.16",
        "expo-crypto": "^55.0.12",
        "expo-dev-client": "~55.0.32",
        "expo-document-picker": "~55.0.11",
        "expo-file-system": "~55.0.19",
        "expo-image-picker": "~55.0.20",
        "expo-linking": "~55.0.15",
        "expo-notifications": "~55.0.22",
        "expo-print": "^55.0.14",
        "expo-router": "~55.0.14",
        "expo-sharing": "~55.0.18",
        "expo-updates": "~55.0.21",
        "fflate": "^0.8.2",
        "heroui-native": "^1.0.1",
        "hyperformula": "^3.2.0",
        "ical.js": "^2.2.1",
        "isomorphic-webcrypto": "^2.3.8",
        "lucide-react-native": "^1.7.0",
        "numfmt": "^3.2.6",
        "pbtsdb": "^0.5.0",
        "pocketbase": "^0.26.8",
        "react": "19.2.0",
        "react-aria": "^3.47.0",
        "react-dom": "19.2.0",
        "react-hook-form": "^7.72.0",
        "react-native": "0.83.6",
        "react-native-blob-util": "^0.24.7",
        "react-native-draggable-flatlist": "^4.0.3",
        "react-native-external-keyboard": "^0.8.4",
        "react-native-gesture-handler": "~2.30.0",
        "react-native-get-random-values": "~1.11.0",
        "react-native-ios-context-menu": "^3.2.1",
        "react-native-ios-utilities": "^5.2.0",
        "react-native-pdf": "^7.0.4",
        "react-native-reanimated": "4.2.1",
        "react-native-safe-area-context": "~5.6.2",
        "react-native-screens": "~4.23.0",
        "react-native-sse": "^1.2.1",
        "react-native-svg": "15.15.3",
        "react-native-web": "^0.21.2",
        "react-native-webview": "13.16.0",
        "react-native-worklets": "0.7.4",
        "react-pdf": "^10.4.1",
        "react-stately": "^3.45.0",
        "tailwind-merge": "^3.5.0",
        "tailwind-variants": "^0.1.20",
        "tinykeys": "^3.0.0",
        "typescript": "~5.9.2",
        "uniwind": "^1.6.2",
        "y-protocols": "^1.0.7",
        "yjs": "^13.6.30",
        "zod": "^4.3.6",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.10",
        "@playwright/test": "^1.52.0",
        "@react-native-community/cli": "^20.1.2",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.2",
        "babel-plugin-module-resolver": "^5.0.3",
        "dotenv-cli": "^11.0.0",
        "esbuild": "^0.28.0",
        "expo-atlas": "^0.4.3",
        "happy-dom": "^20.9.0",
        "imapflow": "^1.3.1",
        "local-ssl-proxy": "^2.0.5",
        "tailwindcss": "^4.2.2",
        "tsx": "^4.21.0",
        "vitest": "^3.0.0"
    }
}
