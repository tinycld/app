{
    "name": "app",
    "version": "0.0.3",
    "private": true,
    "type": "module",
    "main": "expo-router/entry",
    "scripts": {
        "packages:generate": "tsx scripts/generate.ts",
        "assets:copy-pdfjs": "tsx scripts/copy-pdfjs-assets.ts",
        "dev": "tsx scripts/dev.ts",
        "db:reset": "tsx scripts/reset-dev-db.ts",
        "db:reset:demo": "tsx scripts/reset-demo.ts",
        "db:seed": "tsx scripts/seed-db.ts",
        "expo:test": "tsx scripts/reset-dev-db.ts --url http://127.0.0.1:7299 --data-dir server/pb_test_data && tsx scripts/dev.ts --no-ssl --port 7200 --pb-data-dir server/pb_test_data",
        "typecheck": "tinycld-pkg typecheck",
        "lint": "biome check . ../core ../contacts ../mail ../calendar ../drive ../calc ../text ../google-takeout-import",
        "lint:fix": "biome check --write . ../core ../contacts ../mail ../calendar ../drive ../calc ../text ../google-takeout-import",
        "checks": "npm run lint && npm run typecheck",
        "test": "tinycld-pkg test",
        "test:e2e": "tinycld-pkg test:e2e",
        "test:server": "tsx scripts/test-server-api.ts",
        "check": "tinycld-pkg check",
        "pkg:test:unit": "tinycld-pkg test --all",
        "pkg:check": "tinycld-pkg check --all",
        "pkg:test:e2e": "tinycld-pkg test:e2e --all",
        "ssl:generate": "scripts/generate-ssl.sh",
        "simulator": "scripts/ios-simulator.sh",
        "export:web": "expo export --platform web",
        "export:ios": "expo export --platform ios",
        "export:android": "expo export --platform android",
        "eas-build-post-install": "export EXPO_PUBLIC_GIT_COMMIT=$EAS_BUILD_GIT_COMMIT_HASH && ./scripts/eas-install-packages.sh && npm run packages:generate && npm run assets:copy-pdfjs",
        "eas:build:ios": "npx eas build --platform ios",
        "eas:build:ios:local": "npx eas build --platform ios --local --output ./tmp/build.ipa",
        "eas:submit:ios": "npx eas submit --platform ios",
        "eas:submit:ios:local": "npx eas submit --platform ios --path ./tmp/build.ipa",
        "eas:release:ios": "npm run eas:build:ios && npm run eas:submit:ios",
        "eas:release:ios:local": "npm run eas:build:ios:local && npm run eas:submit:ios:local"
    },
