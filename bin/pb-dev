#!/usr/bin/env bash
# Build the Go server and run it in dev mode.
#
# - Loads .env if present (best effort; missing .env is fine because
#   lib/app-config.ts has the defaults the app needs).
# - Builds the binary at server/tinycld.
# - Writes generated TS schema files into core's tree (which lives in the
#   linked sibling), so other consumers of @tinycld/core/types pick them up.
# - Listens on 0.0.0.0:7093; the `ssl:dev` proxy in `bun run dev` fronts
#   this on 7090 with a local cert.
#
# Override the listen address via `bun run pb:dev -- --http 127.0.0.1:8090`.

set -euo pipefail

cd "$(dirname "$0")/.."

if [ -f .env ]; then
    set -a
    # shellcheck disable=SC1091
    . .env
    set +a
fi

cd server
go build -o tinycld .
cd - >/dev/null

exec ./server/tinycld \
    --dev \
    --http 0.0.0.0:7093 \
    --typesDir ../packages/@tinycld/core/types \
    serve "$@"
