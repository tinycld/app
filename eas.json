{
    "cli": {
        "version": ">= 18.7.0",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "channel": "development"
        },
        "preview": {
            "distribution": "internal",
            "channel": "preview"
        },
        "review": {
            "distribution": "internal",
            "channel": "review",
            "env": {
                "EXPO_PUBLIC_APP_REVIEW_MODE": "1"
            }
        },
        "production": {
            "autoIncrement": true,
            "channel": "production",
            "env": {
                "EXPO_PUBLIC_ENV": "production"
            }
        }
    },
    "submit": {
        "production": {}
    }
}
