{
    "expo": {
        "name": "TinyCld",
        "slug": "tinycld",
        "version": "1.13.7",
        "scheme": "tinycld",
        "platforms": ["ios", "android", "web"],
        "userInterfaceStyle": "automatic",
        "plugins": ["expo-router"],
        "icon": "./assets/app-icon.png",
        "splash": {
            "image": "./assets/app-splash.png",
            "resizeMode": "contain",
            "backgroundColor": "#445E82"
        },
        "ios": {
            "bundleIdentifier": "org.tinycld.app",
            "buildNumber": "1",
            "infoPlist": {
                "ITSAppUsesNonExemptEncryption": false
            }
        },
        "android": {
            "package": "org.tinycld.app"
        },
        "web": {
            "bundler": "metro",
            "output": "single"
        },
        "experiments": {
            "typedRoutes": true
        },
        "extra": {
            "router": {},
            "eas": {
                "projectId": "ac921362-6d8a-49a4-b0a5-d5867617bc4d"
            }
        },
        "owner": "nathanstitt"
    }
}
