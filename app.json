{
    "expo": {
        "name": "TinyCld",
        "slug": "tinycld",
        "version": "1.13.7",
        "scheme": "tinycld",
        "platforms": ["ios", "android", "web"],
        "userInterfaceStyle": "automatic",
        "runtimeVersion": { "policy": "appVersion" },
        "updates": {
            "url": "https://u.expo.dev/ac921362-6d8a-49a4-b0a5-d5867617bc4d",
            "fallbackToCacheTimeout": 0
        },
        "plugins": [
            [
                "expo-router",
                {
                    "asyncRoutes": {
                        "web": "production",
                        "default": false
                    }
                }
            ],
            [
                "expo-image-picker",
                {
                    "photosPermission": "Allow TinyCld to access your photos so you can upload them to Drive."
                }
            ],
            "expo-sharing",
            [
                "@sentry/react-native/expo",
                {
                    "organization": "tinycld",
                    "project": "tinycld-app"
                }
            ]
        ],
        "icon": "./assets/app-icon.png",
        "splash": {
            "image": "./assets/app-splash.png",
            "resizeMode": "contain",
            "backgroundColor": "#445E82"
        },
        "ios": {
            "bundleIdentifier": "org.tinycld.app",
            "buildNumber": "1",
            "supportsTablet": true,
            "infoPlist": {
                "ITSAppUsesNonExemptEncryption": false,
                "NSPhotoLibraryAddUsageDescription": "Allow TinyCld to save downloaded images to your Photos library."
            }
        },
        "android": {
            "package": "org.tinycld.app"
        },
        "web": {
            "bundler": "metro",
            "output": "single"
        },
        "experiments": {
            "typedRoutes": true
        },
        "extra": {
            "router": {},
            "eas": {
                "projectId": "ac921362-6d8a-49a4-b0a5-d5867617bc4d"
            }
        },
        "owner": "nathanstitt"
    }
}
