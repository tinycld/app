{
    "compilerOptions": {
        "module": "preserve",
        "moduleResolution": "bundler",
        "customConditions": ["react-native"],
        "jsx": "react-jsx",
        "lib": ["dom", "esnext"],
        "target": "esnext",
        "strict": true,
        "noImplicitAny": false,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "moduleDetection": "force",
        "noEmit": true,
        "types": ["node", "react"]
    }
}
