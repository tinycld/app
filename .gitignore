# Generated by the package generator (route re-exports for linked feature packages)
/app/a/\[orgSlug\]/*/
!/app/a/\[orgSlug\]/settings/
!/app/a/\[orgSlug\]/help/
# Public package routes — one subtree per package with publicRoutes in its
# manifest. Fully generator-owned; the hand-written _layout.tsx sits one level
# up at app/p/_layout.tsx and stays tracked.
/app/p/*/
/lib/generated/
/tinycld.config.ts
/tinycld.seeds.ts
/server/package_extensions.go
/server/go.work
/server/go.work.sum
