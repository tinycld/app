/server/pb_hooks/
/server/tinycld
/server/app
/server/core
/server/pb_data/
/installed-packages.json
/.package-links.json

# Transient release artifacts written into the app member by CI/deploy tooling
# right before `docker build` (never committed).
/.release-id
/.release-manifest

# Native projects — regenerated on demand by `expo prebuild`
ios/
android/
*.xcuserdata
*.hprof

# Design source files
*.afdesign
*.afdesign~lock~


