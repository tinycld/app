{
    "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true,
        "root": "."
    },
    "files": {
        "ignoreUnknown": false,
        "includes": [
            "**/*.ts",
            "**/*.tsx",
            "**/*.js",
            "**/*.jsx",
            "**/*.json",
            "!server",
            "!server/**/*",
            "!**/pb_test_data",
            "!types",
            "!lib/generated",
            "!node_modules",
            "!node_modules/**/*",
            "!app/a/\\[orgSlug\\]/calendar",
            "!app/a/\\[orgSlug\\]/contacts",
            "!app/a/\\[orgSlug\\]/drive",
            "!app/a/\\[orgSlug\\]/mail",
            "!app/share/\\[token\\].tsx",
            "!**/routes.d.ts",
            "!.expo",
            "!.one",
            "!.claude",
            "!ideas",
            "!**/core/types/pbSchema.ts",
            "!**/core/types/pbZodSchema.ts",
            "!**/server",
            "!**/server/**/*",
            "!**/pb-migrations",
            "!**/pb-migrations/**/*",
            "!**/pb-hooks",
            "!**/pb-hooks/**/*",
            "!**/node_modules",
            "!**/node_modules/**/*",
            "!**/.claude",
            "!**/.claude/**/*",
            "!**/.worktrees",
            "!**/.worktrees/**/*",
            "!**/.superpowers",
            "!**/.superpowers/**/*",
            "!**/dist",
            "!**/dist/**/*",
            "!**/test-results",
            "!**/test-results/**/*",
            "!**/webview-editor/build",
            "!**/webview-editor/build/**/*"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 100
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "style": {
                "useConst": "error",
                "useTemplate": "error",
                "useShorthandFunctionType": "error",
                "useConsistentArrayType": {
                    "level": "error",
                    "options": {
                        "syntax": "shorthand"
                    }
                }
            },
            "correctness": {
                "useExhaustiveDependencies": "warn",
                "useHookAtTopLevel": "error",
                "noUnusedVariables": "error"
            },
            "suspicious": {
                "noDebugger": "error",
                "noConsole": "warn",
                "noVar": "error",
                "noExplicitAny": "error"
            },
            "complexity": {
                "noExcessiveCognitiveComplexity": {
                    "level": "warn",
                    "options": {
                        "maxAllowedComplexity": 45
                    }
                }
            }
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "quoteProperties": "asNeeded",
            "trailingCommas": "es5",
            "semicolons": "asNeeded",
            "arrowParentheses": "asNeeded"
        }
    },
    "overrides": [
        {
            "includes": [
                "**/scripts/**/*",
                "**/tests/**/*",
                "**/*.test.ts",
                "**/*.test.tsx",
                "**/package-scripts/**/*"
            ],
            "linter": {
                "rules": {
                    "suspicious": {
                        "noConsole": "off"
                    },
                    "style": {
                        "noNonNullAssertion": "off"
                    }
                }
            }
        }
    ],
    "assist": {
        "enabled": true,
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        }
    }
}
